<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyImmo.App.MainPage"
             BackgroundColor="{StaticResource NavigationBackgroundColor}">

    <Border BackgroundColor="{StaticResource PageBackgroundColor}"
            StrokeThickness="1"
            Stroke="{StaticResource BorderColor}"
            Padding="20">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20,0,0,0"/>
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto, Auto, *" RowSpacing="20">

            <Border Grid.Row="0"
                    StrokeThickness="1"
                    Stroke="{StaticResource BorderColor}">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0078D4" Offset="0.0" />
                        <GradientStop Color="#00457E" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>

                <Label Text="Bienvenue dans EasyImmo"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="16"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Padding="0,100" />
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,*,*,*" 
                  RowDefinitions="150" 
                  ColumnSpacing="15">

                <!-- Propriétés -->
                <Border Grid.Row="0" Grid.Column="0" StrokeThickness="1" Stroke="{StaticResource BorderColor}" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                        <Label Text="{Binding PropertiesCount}" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Propriétés" FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Personnes -->
                <Border Grid.Row="0" Grid.Column="1" StrokeThickness="1" Stroke="{StaticResource BorderColor}" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                        <Label Text="{Binding PeopleCount}" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Personnes" FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Dossiers -->
                <Border Grid.Row="0" Grid.Column="2" StrokeThickness="1" Stroke="{StaticResource BorderColor}" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                        <Label Text="{Binding FoldersCount}" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Dossiers" FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Rendez-vous -->
                <Border Grid.Row="0" Grid.Column="3" StrokeThickness="1" Stroke="{StaticResource BorderColor}" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                        <Label Text="0" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Rendez-vous" FontSize="14" TextColor="Gray" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="15">

                <!-- Dernières propriétés -->
                <Border Grid.Column="0" StrokeThickness="1" Stroke="{StaticResource BorderColor}" BackgroundColor="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid RowDefinitions="Auto, *">
                        <Label Grid.Row="0" Text="Dernières propriétés ajoutées" FontSize="18" FontAttributes="Bold" Margin="0,0,0,15" />
                    </Grid>
                </Border>

                <!-- Derniers dossiers ouverts -->
                <Border Grid.Column="1" StrokeThickness="1" Stroke="{StaticResource BorderColor}" BackgroundColor="White" Padding="15">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>

                    <Grid RowDefinitions="Auto, *">
                        <Label Grid.Row="0" Text="Derniers dossiers ouverts" FontSize="18" FontAttributes="Bold" Margin="0,0,0,15" />
                    </Grid>
                </Border>

            </Grid>

        </Grid>

    </Border>
</ContentPage>