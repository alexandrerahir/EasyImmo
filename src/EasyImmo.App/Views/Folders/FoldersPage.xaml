<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyImmo.App.Views.Folders.FoldersPage"
             BackgroundColor="{StaticResource NavigationBackgroundColor}">

    <Border BackgroundColor="{StaticResource PageBackgroundColor}"
            StrokeThickness="1"
            Stroke="{StaticResource BorderColor}"
            Padding="20">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20,0,0,0"/>
        </Border.StrokeShape>

        <Grid RowDefinitions="Auto, Auto, *">

            <!-- Header -->
            <VerticalStackLayout Grid.Row="0">
                <Label Text="Dossiers" FontSize="24" FontFamily="OpenSansSemibold" FontAttributes="Bold" TextColor="Black"/>
                <Label Text="Gérez les documents et pièces justificatives associés" TextColor="Gray"/>
            </VerticalStackLayout>

            <!-- Barre d'action -->
            <HorizontalStackLayout Grid.Row="1" Spacing="5" Margin="0,20,0,20">

                <SearchBar Placeholder="Rechercher un dossier"
                           WidthRequest="250"
                           HeightRequest="34"/>

                <Picker ItemsSource="{Binding FilterOptions}"
                        SelectedItem="{Binding SelectedFilter}"
                        WidthRequest="150"
                        HeightRequest="34"/>

                <Label Text="{Binding Folders.Count, StringFormat='{0} dossier(s) trouvé(s)'}"
                       VerticalTextAlignment="Center"
                       TextColor="Black"
                       FontSize="14"/>

            </HorizontalStackLayout>

            <!-- Liste des dossiers -->
            <CollectionView Grid.Row="2"
                            x:Name="FoldersCollection"
                            ItemsSource="{Binding Folders}"
                            SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeShape="RoundRectangle 7"
                                HeightRequest="70"
                                BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="{StaticResource BorderColor}"
                                Padding="20,0">

                            <Grid ColumnDefinitions="*, 100, Auto" ColumnSpacing="15" VerticalOptions="Center">

                                <HorizontalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="15">

                                    <!-- Icône de dossier -->
                                    <Label Text="&#xe838;"
                                           FontFamily="FluentIcons"
                                           FontSize="24"
                                           TextColor="Black"
                                           VerticalOptions="Center"/>

                                    <!-- Informations -->
                                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Folder.FolderId, StringFormat='Dossier numéro {0}'}" FontAttributes="Bold" TextColor="Black"/>
                                        <Label Text="{Binding PersonFullName}" TextColor="Gray" FontSize="14"/>
                                    </VerticalStackLayout>

                                </HorizontalStackLayout>

                                <!-- Statut du dossier -->
                                <Label Grid.Column="1"
                                       Text="{Binding Status}"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       TextColor="Gray"
                                       FontAttributes="Italic"/>

                                <HorizontalStackLayout Grid.Column="2"
                                                       Spacing="10"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="End">

                                    <!-- Bouton détails -->
                                    <Button Text="&#xE7b3;"
                                            TextColor="White"
                                            FontFamily="Segoe Fluent Icons"
                                            ToolTipProperties.Text="Voir les détails de ce dossier"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DetailsFolderCommand}"
                                            CommandParameter="{Binding .}"/>

                                    <!-- Bouton supprimer -->
                                    <Button Text="&#xE74D;"
                                            TextColor="White"
                                            FontFamily="Segoe Fluent Icons"
                                            ToolTipProperties.Text="Supprimer ce dossier"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteFolderCommand}"
                                            CommandParameter="{Binding .}"/>

                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Border>
</ContentPage>
