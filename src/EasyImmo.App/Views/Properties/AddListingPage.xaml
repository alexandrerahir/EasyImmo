<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyImmo.App.Views.Properties.AddListingPage"
             BackgroundColor="{StaticResource NavigationBackgroundColor}">

    <Border BackgroundColor="{StaticResource PageBackgroundColor}"
            StrokeThickness="1"
            Stroke="{StaticResource BorderColor}"
            Padding="20">

        <Border.StrokeShape>
            <RoundRectangle CornerRadius="20,0,0,0"/>
        </Border.StrokeShape>

        <ScrollView>
            <VerticalStackLayout Spacing="20">

                <!-- Header -->
                <VerticalStackLayout>
                    <Label Text="Ajouter une annonce" FontSize="24" FontAttributes="Bold" TextColor="Black"/>
                    <Label Text="Définissez les prix, l'agent en charge et les frais associés pour ce bien." TextColor="Gray"/>
                </VerticalStackLayout>


                <!-- Information général -->
                <Border Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="20">

                    <VerticalStackLayout Spacing="20">
                        <Label Text="Informations générales" FontAttributes="Bold" FontSize="16" TextColor="Black"/>

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                            <!-- Type d'annonce -->
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="Type d'annonce" TextColor="Black" FontSize="14" />
                                <Picker ItemsSource="{Binding ListingTypes}"
                                        ItemDisplayBinding="{Binding ListingTypeName}"
                                        SelectedItem="{Binding SelectedListingType}"/>
                            </VerticalStackLayout>

                            <!-- Agent -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Agent en charge" TextColor="Black" FontSize="14" />
                                <Picker ItemsSource="{Binding Agents}"
                                        ItemDisplayBinding="{Binding LastNameAgent}"
                                        SelectedItem="{Binding SelectedAgent}"/>
                            </VerticalStackLayout>
                        </Grid>
                        
                        <!-- Prix principal -->
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Prix (Vente ou Loyer)" TextColor="Black" FontSize="14" />
                            <Entry Text="{Binding ListingPrice}" Placeholder="Ex: 250000" Keyboard="Numeric" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>


                <!-- Ventes et locations -->
                <Border Stroke="{StaticResource BorderColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 12"
                        BackgroundColor="White"
                        Padding="20">

                    <VerticalStackLayout Spacing="20">

                        <!-- Frais Vente -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Pour une vente" FontAttributes="Bold" FontSize="16" TextColor="Black"/>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Frais d'agence" TextColor="Black" FontSize="14" />
                                    <Entry Text="{Binding AgencyFees}" Placeholder="Ex: 7500" Keyboard="Numeric" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Frais de notaire" TextColor="Black" FontSize="14" />
                                    <Entry Text="{Binding NotaryFees}" Placeholder="Ex: 25000" Keyboard="Numeric" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Frais Location -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Pour une location" FontAttributes="Bold" FontSize="16" TextColor="Black"/>

                            <Grid ColumnDefinitions="*, *" ColumnSpacing="20">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Charges" TextColor="Black" FontSize="14" />
                                    <Entry Text="{Binding RentalCharge}" Placeholder="Ex: 50" Keyboard="Numeric" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Garantie locative" TextColor="Black" FontSize="14" />
                                    <Entry Text="{Binding RentalWarranty}" Placeholder="Ex: 1500" Keyboard="Numeric" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Bouton ajouter -->
                <Button Text="Ajouter l'annonce"
                        Margin="0,10,0,0"
                        Command="{Binding SaveCommand}"/>

            </VerticalStackLayout>
        </ScrollView>

    </Border>

</ContentPage>