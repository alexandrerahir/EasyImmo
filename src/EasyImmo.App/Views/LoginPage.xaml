<?xml version="1.0" encoding="utf-8" ?>
<!--
    LoginPage.xaml
    Page de connexion de l'application EasyImmo.
-->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyImmo.App.Views.LoginPage"
             Title="LoginPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False">

    <!-- Arrière-plan en dégradé pour la page de connexion -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#80D3E3FF" Offset="0.0" />
            <GradientStop Color="#40F5F0EE" Offset="0.5" />
            <GradientStop Color="#80FFDBC8" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <!-- Conteneur central pour le formulaire de connexion -->
    <Border VerticalOptions="Center" 
            HorizontalOptions="Center"
            WidthRequest="400"
            Padding="40"
            StrokeThickness="0"
            BackgroundColor="White">

        <!-- Bordure arrondie pour le conteneur du formulaire -->
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="12" />
        </Border.StrokeShape>

        <!-- Ombre pour le conteneur du formulaire -->
        <Border.Shadow>
            <Shadow Brush="Black"
                        Offset="0,10"
                        Radius="20"
                        Opacity="0.1" />
        </Border.Shadow>

        <!-- Contenu du formulaire de connexion -->
        <VerticalStackLayout Spacing="10">

            <!-- Titre de la page de connexion -->
            <Label Text="Se connecter" 
                   FontFamily="SegoeUI"
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="Black" />

            <!-- Sous-titre de la page de connexion -->
            <Label Text="Utilisez votre compte EasyImmo" 
                   FontFamily="SegoeUI"
                   FontSize="14"
                   TextColor="Gray" 
                   Margin="0,0,0,0" />

            <!-- Texte d'erreur affiché en cas d'erreur de connexion -->
            <Label x:Name="ErrorLabel"
                   Text="{Binding ErrorMessage}"
                   TextColor="#D32F2F"
                   FontFamily="SegoeUI"
                   FontSize="14"
                   IsVisible="{Binding IsErrorVisible}" />

            <!-- Champ de saisie pour l'adresse email -->
            <VerticalStackLayout Margin="0,0,0,10" Spacing="5">
                <Label Text="Adresse mail" FontFamily="SegoeUI" FontSize="14" />
                <Entry Text="{Binding Email}" Placeholder="nom@exemple.com" />
            </VerticalStackLayout>

            <!-- Champ de saisie pour le mot de passe -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Mot de passe" FontFamily="SegoeUI" FontSize="14" />
                <Entry Text="{Binding Password}" Placeholder="●●●●●●●●●●" IsPassword="True" />
            </VerticalStackLayout>

            <!-- Bouton de connexion -->
            <Button Text="Se connecter" 
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource PrimaryButton}"/>

            <!-- Séparateur visuel entre les méthodes de connexion -->
            <Grid ColumnDefinitions="*,Auto,*" VerticalOptions="Center">
                <BoxView Grid.Column="0" Color="#DADADA" HeightRequest="1" VerticalOptions="Center" />
                <Label   Grid.Column="1" Text="OU" FontFamily="SegoeUI" FontSize="12" TextColor="#DADADA" Margin="10,0" />
                <BoxView Grid.Column="2" Color="#DADADA" HeightRequest="1" VerticalOptions="Center" />
            </Grid>

            <!-- Bouton de connexion Microsoft -->
            <Button Text="Se connecter avec Microsoft"
                    TextColor="#8C8C8C"
                    BackgroundColor="Transparent"
                    BorderColor="#8C8C8C"
                    BorderWidth="1"
                    ImageSource="microsoft.png"
                    ContentLayout="Left,10"/>

        </VerticalStackLayout>

    </Border>

</ContentPage>
