<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="EasyImmo.App.Controls.Header">

    <Border 
        Stroke="#C7C7C7"
        StrokeThickness="1"
        Padding="15"
        StrokeShape="RoundRectangle 0,20,0,20"
        BackgroundColor="White">

        <VerticalStackLayout>
            <Label Text="EasyImmo." FontFamily="PoppinsBold" FontSize="24" HorizontalTextAlignment="Center" TextColor="#FF6262"/>
            <BoxView HeightRequest="2" BackgroundColor="#C7C7C7" Margin="0,25,0,25"/>
            <Label Text="Accueil"/>
            <Label Text="Statistiques"/>
            <Label Text="Paramètres"/>
        </VerticalStackLayout>

    </Border>

</ContentView>
